# ─── Core ───────────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=3001
# Public URL of the app (used for OAuth callbacks). e.g. https://foreman.up.railway.app
APP_URL=http://localhost:3001
# Comma-separated origins allowed to hit the API (the web dev server).
WEB_ORIGIN=http://localhost:5173

# ─── App auth (single user) ─────────────────────────────────────────────────
# The single login this self-hosted tool accepts.
AUTH_USERNAME=admin
# bcrypt hash of your password. Generate with: pnpm --filter @foreman/server hash-password '<pw>'
AUTH_PASSWORD_HASH=
# Secret used to sign session cookies (32+ random chars).
SESSION_SECRET=

# ─── Secrets encryption ─────────────────────────────────────────────────────
# 32-byte key, base64 or hex. Generate with: openssl rand -base64 32
MASTER_ENCRYPTION_KEY=

# ─── Database ───────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/foreman?schema=public

# ─── Claude Agent SDK ───────────────────────────────────────────────────────
# API key — used for Module 2 (Web Creator / client work), billed pay-as-you-go.
ANTHROPIC_API_KEY=
# Subscription OAuth token from `claude setup-token` (needs Pro/Max). Used for
# Module 1 (Software Creator) so it bills against your Max plan instead.
# NOTE: if ANTHROPIC_API_KEY is also set in the same process the API key wins,
# so Foreman sets exactly one per session depending on the module.
CLAUDE_CODE_OAUTH_TOKEN=
# Model the orchestrated Claude Code uses.
AGENT_MODEL=claude-opus-4-8
# Safety caps.
MAX_CONCURRENT_SESSIONS=3
SESSION_COST_LIMIT_USD=10

# ─── GitHub OAuth App ───────────────────────────────────────────────────────
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
# Bot identity used for commits the orchestrator makes.
GIT_AUTHOR_NAME=Foreman Bot
GIT_AUTHOR_EMAIL=foreman-bot@users.noreply.github.com

# ─── Gemini (logo generation) ───────────────────────────────────────────────
GEMINI_API_KEY=
GEMINI_IMAGE_MODEL=gemini-2.5-flash-image

# ─── Working dir for cloned project repos ───────────────────────────────────
WORKSPACES_DIR=./workspaces

# ─── Error capture & alerting ───────────────────────────────────────────────
# Hosting platform label stamped on error rows (informational).
PLATFORM=railway
# Webhook the HIGH/CRITICAL alert digest POSTs to (Slack incoming-webhook URL,
# or any endpoint that accepts JSON {text, errors[]}). Leave blank to disable
# paging — errors are still recorded in the ErrorLog table either way.
ALERT_WEBHOOK_URL=
# How often the notifier scans for unsent HIGH/CRITICAL errors (ms). Default 5m.
ALERT_POLL_INTERVAL_MS=300000
